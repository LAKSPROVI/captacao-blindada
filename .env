# =============================================================================
# CAPTAÇÃO BLINDADA - Variáveis de Ambiente
# =============================================================================
# Configuração para Desenvolvimento
# Para Produção: IS_PRODUCTION=true e JWT_SECRET_KEY=g-chave-segura-gerada

# -----------------------------------------------------------------------------
# MODO
# -----------------------------------------------------------------------------
IS_PRODUCTION=false

# -----------------------------------------------------------------------------
# SEGURANÇA
# -----------------------------------------------------------------------------
JWT_SECRET_KEY=dev-key-0123456789abcdef0123456789abcdef0123456789abcdef0123456789

# -----------------------------------------------------------------------------
# ADMIN
# -----------------------------------------------------------------------------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# -----------------------------------------------------------------------------
# BANCO
# -----------------------------------------------------------------------------
CAPTACAO_DB_PATH=/app/data/captacao_blindada.db

# -----------------------------------------------------------------------------
# FONTES (OPICIONAL)
# -----------------------------------------------------------------------------
# DATAJUD_API_URL=https://api.datajud.tjsp.jus.br/api/v1
# DJEN_API_URL=https://dje.tjsp.jus.br/api/v2
# BRIGHT_DATA_ZONE=your-zone
# BRIGHT_DATA_USERNAME=your-user
# BRIGHT_DATA_PASSWORD=your-pass

# -----------------------------------------------------------------------------
# IA (OPCIONAL)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=sk-your-key
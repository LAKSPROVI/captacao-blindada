# ============================================================
# CAPTAÇÃO BLINDADA - Variáveis de Ambiente
# ============================================================
# Copie este arquivo para .env e preencha os valores

# ============================================================
# MODO DE PRODUÇÃO (OBRIGATÓRIO)
# ============================================================
# Defina como true para produção
IS_PRODUCTION=false

# ============================================================
# SEGURANÇA - JWT (OBRIGATÓRIO EM PRODUÇÃO)
# ============================================================
# Chave secreta para tokens JWT - MINIMO 32 caracteres!
# Gere uma chave segura: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=

# ============================================================
# ADMINISTRADOR
# ============================================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin  # Mude em produção!

# ============================================================
# BANCO DE DADOS
# ============================================================
CAPTACAO_DB_PATH=/app/data/captacao_blindada.db

# ============================================================
# FONTES DE DADOS - API KEYS
# ============================================================
# DataJud (CNJ) - gratuito
DATAJUD_API_URL=https://api.datajud.tjsp.jus.br/api/v1

# DJEN (CNJ) - gratuito
DJEN_API_URL=https://dje.tjsp.jus.br/api/v2

# TJSP DJe - Web Scraping
# TJSP_COOKIE_SESSION=your-tjsp-session-cookie

# Bright Data (Proxy Residencial Brasileiro - Opcional)
# BRIGHT_DATA_ZONE=your-zone
# BRIGHT_DATA_USERNAME=your-username
# BRIGHT_DATA_PASSWORD=your-password

# Querido Diário (Opcional)
# QUERIDO_DIARIO_API_KEY=your-api-key

# JusBrasil (Opcional)
# JUSBRASIL_API_KEY=your-api-key

# ============================================================
# INTELIGÊNCIA ARTIFICIAL (Opcional)
# ============================================================
# OpenAI
# OPENAI_API_KEY=sk-your-key

# Claude (Anthropic)
# ANTHROPIC_API_KEY=sk-ant-your-key

# ============================================================
# NOTIFICAÇÕES (Opcional)
# ============================================================
# WhatsApp Business API
# WHATSAPP_TOKEN=your-whatsapp-token
# WHATSAPP_PHONE_ID=your-phone-id

# Email (SMTP)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=your-email@gmail.com
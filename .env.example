# ============================================================
# CAPTAÇÃO BLINDADA - Variáveis de Ambiente
# ============================================================
# Copie este arquivo para .env e preencha os valores

# ============================================================
# MODO DE PRODUÇÃO (OBRIGATÓRIO)
# ============================================================
IS_PRODUCTION=false

# ============================================================
# SEGURANÇA - JWT (OBRIGATÓRIO EM PRODUÇÃO)
# ============================================================
# Chave secreta para tokens JWT - MINIMO 32 caracteres!
# Gere uma chave segura: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=

# ============================================================
# SEGURANÇA - CRIPTOGRAFIA DE API KEYS (OBRIGATÓRIO)
# ============================================================
# Chave usada para criptografar API keys de IA no banco de dados.
# Gere uma chave segura: python -c "import secrets; print(secrets.token_hex(32))"
# ATENÇÃO: Se alterar esta chave, as API keys já salvas não poderão ser descriptografadas!
ENCRYPTION_KEY=

# ============================================================
# ADMINISTRADOR (OBRIGATÓRIO)
# ============================================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# ============================================================
# BANCO DE DADOS
# ============================================================
CAPTACAO_DB_PATH=/app/data/captacao_blindada.db

# ============================================================
# FONTES DE DADOS - API KEYS
# ============================================================
# DataJud (CNJ)
DATAJUD_API_KEY=
DATAJUD_BASE_URL=https://api-publica.datajud.cnj.jus.br

# DJEN (CNJ)
DJEN_API_BASE_URL=https://comunicaapi.pje.jus.br

# ============================================================
# BRIGHT DATA - PROXY (necessário para fontes que exigem IP BR)
# ============================================================
# URL completa do proxy (usado como fallback em djen_source.py)
# Formato: http://username:password@host:port
BRIGHTDATA_PROXY_URL=

# Proxy residencial
BRIGHTDATA_RESIDENTIAL_SERVER=
BRIGHTDATA_RESIDENTIAL_USERNAME=
BRIGHTDATA_RESIDENTIAL_PASSWORD=

# Web Unlocker
BRIGHTDATA_WEB_UNLOCKER_URL=https://api.brightdata.com/request
BRIGHTDATA_WEB_UNLOCKER_ZONE=
BRIGHTDATA_API_KEY=

# Scraping Browser (WebSocket)
BRIGHTDATA_SCRAPING_BROWSER_WS=

# Settings.py proxy (alternativo)
BRIGHT_DATA_PROXY_USERNAME=
BRIGHT_DATA_PROXY_PASSWORD=
BRIGHT_DATA_PROXY_HOST=brd.superproxy.io
BRIGHT_DATA_PROXY_PORT=33335

# ============================================================
# INTELIGÊNCIA ARTIFICIAL (Opcional)
# ============================================================
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# LLM_API_URL=
# LLM_API_KEY=
# LLM_MODEL=gpt-4.1-mini

# ============================================================
# NOTIFICAÇÕES (Opcional)
# ============================================================
# WHATSAPP_TOKEN=
# WHATSAPP_PHONE_ID=
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=
